generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
    // output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
}

enum Role {
    OWNER
    SITTER
    ADMIN
}

enum Status {
    ACTIVE
    SUSPENDED
}

enum ServiceType {
    WALKING
    BOARDING
    DAYCARE
    SITTING
}

enum BookingStatus {
    PENDING
    CONFIRMED
    CANCELLED
    COMPLETED
}

// One User - one / multiple pets

model User {
    id       String @id @default(uuid())
    name     String
    email    String @unique
    password String
    role     Role
    status   Status @default(ACTIVE)

    createdAt      DateTime        @default(now())
    updatedAt      DateTime        @updatedAt
    pets           Pet[]
    sitterProfiles SitterProfile[]
    bookings       Booking[]

    @@index([status])
    @@map("users")
}

model Pet {
    id      String @id @default(uuid())
    name    String
    breed   String
    age     String
    notes   String
    ownerId String
    petCode String @unique

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // relation : 1 to many (1 owner TO one or multiple pets)
    owner    User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
    bookings Booking[]

    @@unique([name, breed, age, ownerId])
    @@map("pets")
}

model SitterProfile {
    id         String   @id @default(uuid())
    bio        String
    experience Int
    hourlyRate Float?
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    sitterId String    @unique
    user     User      @relation(fields: [sitterId], references: [id])
    services Service[]
    bookings Booking[]
}

model Service {
    id          String      @id @default(uuid())
    serviceType ServiceType
    price       Float
    description String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    sitterId String

    sitter   SitterProfile @relation(fields: [sitterId], references: [id])
    bookings Booking[]
}

model Booking {
    id String @id @default(uuid())

    ownerId   String
    sitterId  String
    petId     String
    serviceId String

    startDate DateTime
    endDate   DateTime

    totalPrice Float
    status     BookingStatus @default(PENDING)
    notes      String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    owner   User          @relation(fields: [ownerId], references: [id])
    sitter  SitterProfile @relation(fields: [sitterId], references: [id])
    pet     Pet           @relation(fields: [petId], references: [id])
    service Service       @relation(fields: [serviceId], references: [id])

    @@map("bookings")
}
